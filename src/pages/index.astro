---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { Image } from "astro:assets";
import logo from "../assets/logo.svg";


const projects = [
  {
    title: "SVC Commerce",
    description: "A comprehensive Laravel 12 back-office platform managing catalog, inventory workflows, sales, deliveries, and PayMongo payment integration.",
    tags: ["Laravel", "Filament", "Livewire", "TailwindCSS", "PostgreSQL"],
    githubUrl: "https://github.com/KaiyouS/svc-commerce", 
    imageUrl: "/images/svc-commerce.jpg"
  },
  {
    title: "GradPass",
    description: "A multi-platform clearance tracker resolving university administrative bottlenecks. Features role-based workflows for students, staff, and admins.",
    tags: ["Flutter", "Supabase", "Edge Functions", "Dart"],
    githubUrl: "https://github.com/KaiyouS/student_clearance_tracker",
    imageUrl: "/images/gradpass.jpg"
  },
  {
    title: "CSSEC Web Portal",
    description: "Architected a headless WordPress CMS to serve dynamic content via REST API. Configured content models and endpoints to seamlessly supply data to a decoupled React/Vite frontend built by collaborative team members.",
    tags: ["WordPress", "Headless CMS", "REST API", "Backend Architecture"],
    liveUrl: "https://addu-cssec-website.netlify.app/",
    imageUrl: "/images/cssec.jpg" 
  },
  {
    title: "AdDU Rebrand",
    description: "A modern, event-driven website redesign featuring dynamic content rendering from JSON, custom search overlays, and responsive mobile architecture.",
    tags: ["Vanilla JS", "HTML5", "CSS3", "DOM Manipulation"],
    githubUrl: "https://github.com/KaiyouS/addu-website-rebranding",
    liveUrl: "https://kaiyous.github.io/addu-website-rebranding/",
    imageUrl: "/images/addu-rebrand.jpg"
  },
  {
    title: "IMS Desktop",
    description: "A robust Java Swing desktop application for managing inventory, suppliers, and purchase orders, backed by a relational database.",
    tags: ["Java", "Swing", "MySQL", "OOP"],
    githubUrl: "https://github.com/KaiyouS/ims-db-exercises",
    imageUrl: "/images/ims.jpg"
  }
];
---
<Layout title="Kaiyou | Full-Stack Developer">
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <h1>
          Hi, I'm Kaiyou.<br />
          <small>Full-Stack Developer</small>
        </h1>

        <p>
        I’m a full-stack developer who believes software should be as much of a pleasure 
        to maintain as it is to use. I focus on writing clean, readable code and following 
        best practices—not because they’re rules, but because they make better products. 
        </p>
        <p>
        When I'm not in the terminal, I’m usually thinking through a <strong>chess</strong> move, 
        listening to a <strong>ballad</strong>, or looking for a clear sky to <strong>stargaze</strong>.
        </p>

        <div class="hero-actions">
          <Button href="#project">View My Work</Button>
          <Button href="/contact" variant="secondary">Get in Touch</Button>
        </div>
      </div>

      <div class="hero-image">
        <Image
          src={ logo }
          alt="A photo of Kaiyou"
          class="content"
          loading="eager"
        />
      </div>
    </div>
  </section>
  
  <section id="projects" class="section projects-section">
    <div class="container">
      <div class="section-header">
        <h2>Selected Works</h2>
        <p>A collection of applications I've built focusing on complex workflows, responsive design, and scalable architecture.</p>
      </div>

      <div class="projects-grid">
        {projects.map((project) => (
          <ProjectCard 
            title={project.title}
            description={project.description}
            tags={project.tags}
            githubUrl={project.githubUrl}
            liveUrl={project.liveUrl}
            imageUrl={project.imageUrl}
          />
        ))}
      </div>
    </div>
  </section>
  
</Layout>

<style>
  .hero {
    padding-top: var(--spacing-section);
    padding-bottom: var(--spacing-section);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  @media (min-width: 47.5rem) {
    .hero-inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .hero-content {
    flex: 1;
    max-width: var(--max-text-width);
  }

  h1 small {
    color: var(--color-text);
    font-size: var(--text-lg);
    font-weight: 300;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-image {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .hero-image .content {
    width: 100%;
    max-width: 380px;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    transform: rotate(2deg);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    
    &:hover {
      transform: rotate(0deg);
    }
  }

  .section {
    padding-top: var(--spacing-section);
    padding-bottom: var(--spacing-section);
  }

  .section-header {
    margin-bottom: 4rem;
    max-width: 600px;
  }

  .section-header p {
    font-size: 1.1rem;
    opacity: 0.8;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 48rem) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
