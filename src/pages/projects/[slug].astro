---
import { getCollection, type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import Button from "@components/Button.astro";
import Layout from "@layouts/Layout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { title, description, tags, images, githubUrl, liveUrl } = project.data;

const desktopImages = images.filter((img) => img.device === "desktop");
const mobileImages = images.filter((img) => img.device === "mobile");
const hasMultipleDevices = desktopImages.length > 0 && mobileImages.length > 0;
---

<Layout
  title={`${title} | Kaiyou`}
  description={description}
  image={images[0].src.src}
>
  <article class="project-detail">
    <div class="container">
      <!-- Header -->
      <header class="project-header">
        <a href="/projects" class="back-link">&larr; All Projects</a>
        <h1>{title}</h1>
        <div class="tags">
          {tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
        <p class="description">{description}</p>
        <div class="actions">
          { githubUrl && (
            <Button href={githubUrl}>GitHub &rarr;</Button>
          )}
          { liveUrl && (
            <Button href={liveUrl} variant="secondary">Live Demo &rarr;</Button>
          )}
        </div>
      </header>

      <!-- Image Gallery -->
      <section class="gallery" aria-label="Project screenshots">
        {
          desktopImages.length > 0 && mobileImages.length > 0 && (
            <div
              class="filter-bar"
              role="group"
              aria-label="Filter screenshots by device"
            >
              <button class="filter-btn active" data-filter="all">
                All
              </button>
              <button class="filter-btn" data-filter="desktop">
                Desktop
              </button>
              <button class="filter-btn" data-filter="mobile">
                Mobile
              </button>
            </div>
          )
        }

        <div class="gallery-groups">
          {
            desktopImages.length > 0 && (
              <div class="gallery-group" data-device="desktop">
                {hasMultipleDevices && <p class="device-label">Desktop</p>}
                <div class="desktop-grid">
                  {desktopImages.map((img) => (
                    <div class="desktop-frame">
                      <div class="browser-bar">
                        <span class="dot" />
                        <span class="dot" />
                        <span class="dot" />
                      </div>
                      <div class="desktop-screen">
                        <Image src={img.src} alt={img.alt} />
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )
          }

          {
            mobileImages.length > 0 && (
              <div class="gallery-group" data-device="mobile">
                {hasMultipleDevices && <p class="device-label">Mobile</p>}
                <div class="mobile-grid">
                  {mobileImages.map((img) => (
                    <div class="phone-frame">
                      <div class="phone-screen">
                        <Image src={img.src} alt={img.alt} />
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )
          }
        </div>
      </section>
    </div>
  </article>
</Layout>

<style>
  .project-detail {
    padding-top: var(--spacing-section);
    padding-bottom: var(--spacing-section);
  }

  /* Header */
  .project-header {
    max-width: 720px;
    margin-bottom: 4rem;

    h1 {
      margin-top: 1rem;
      margin-bottom: 1rem;
    }
  }

  .back-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-primary);
    opacity: 0.8;
    transition: opacity 0.2s ease;

    &:hover {
      opacity: 1;
    }
  }
  .tags {
    flex-wrap: wrap;
  }

  .description {
    font-size: var(--text-normal);
    opacity: 0.85;
    max-width: 65ch;
    margin-bottom: 2rem;
  }

  .actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Gallery */
  .gallery {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .gallery-group {
    display: flex;
    flex-direction: column;
    padding-bottom: 2.5rem;
    gap: 1rem;
  }

  .device-label {
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary-light);
    opacity: 0.7;
    margin: 0;
  }

  /* Desktop frames */
  .desktop-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;

    @media (min-width: 48rem) {
      grid-template-columns: repeat(auto-fit, minmax(480px, 1fr));
    }
  }

  .desktop-frame {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: var(--shadow);
    background: rgba(255, 255, 255, 0.03);
  }

  .desktop-screen img {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  /* Phone frames */
  .mobile-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .phone-frame {
    position: relative;
    width: 220px;
    border: 2px solid rgba(255, 255, 255, 0.15);
    border-radius: 0.5rem;
    overflow: hidden;
    box-shadow:
      var(--shadow);
    background: rgba(255, 255, 255, 0.03);
    flex-shrink: 0;
  }

  .phone-screen img {
    width: 100%;
    height: auto;
    aspect-ratio: 9 / 19.5;
    object-fit: cover;
    display: block;
  }

  .filter-bar {
    display: flex;
    gap: 0.5rem;
  }

  .filter-btn {
    all: unset;
    cursor: pointer;
    font-family: var(--font-text);
    font-size: var(--text-xs);
    font-weight: 500;
    padding: 0.35rem 0.875rem;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: var(--color-text);
    opacity: 0.6;
    transition: all 0.2s ease;

    &:hover {
      opacity: 1;
      border-color: rgba(255, 255, 255, 0.3);
    }

    &.active {
      background: var(--color-primary-bg);
      border-color: var(--color-primary);
      color: var(--color-primary-light);
      opacity: 1;
    }

    &:focus-visible {
      outline: 2px solid var(--color-primary);
      outline-offset: 2px;
    }
  }

  .gallery-group {
    transition: opacity 0.2s ease;

    &.hidden {
      display: none;
    }
  }
</style>

<script>
  const filterBtns =
    document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const groups = document.querySelectorAll<HTMLElement>(
    ".gallery-group[data-device]",
  );

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;

      // Update active button
      filterBtns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");

      // Show/hide groups
      groups.forEach((group) => {
        const device = group.dataset.device;
        const visible = filter === "all" || filter === device;
        group.classList.toggle("hidden", !visible);
      });
    });
  });
</script>
