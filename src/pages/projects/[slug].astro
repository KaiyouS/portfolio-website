---
import { getCollection, type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import Button from "@components/Button.astro";
import Layout from "@layouts/Layout.astro";
import "@fancyapps/ui/dist/fancybox/fancybox.css";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { title, description, tags, images, githubUrl, liveUrl } = project.data;

const desktopImages = images.filter((img) => img.device === "desktop");
const mobileImages = images.filter((img) => img.device === "mobile");
const hasMultipleDevices = desktopImages.length > 0 && mobileImages.length > 0;
---

<Layout
  title={`${title} | Kaiyou`}
  description={description}
  image={images[0].src.src}
>
  <article class="project-detail">
    <div class="container">
      <!-- Header -->
      <header class="project-header">
        <a href="/projects" class="back-link">&larr; All Projects</a>
        <h1>{title}</h1>
        <div class="tags">
          {tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
        <p class="description">{description}</p>
        <div class="actions">
          {githubUrl && <Button href={githubUrl}>GitHub &rarr;</Button>}
          {
            liveUrl && (
              <Button href={liveUrl} variant="secondary">
                Live Demo &rarr;
              </Button>
            )
          }
        </div>
      </header>

      <!-- Image Gallery -->
      <section class="gallery" aria-label="Project screenshots">
        {
          desktopImages.length > 0 && mobileImages.length > 0 && (
            <div
              class="filter-bar"
              role="group"
              aria-label="Filter screenshots by device"
            >
              <button class="filter-btn active" data-filter="all">
                All
              </button>
              <button class="filter-btn" data-filter="desktop">
                Desktop
              </button>
              <button class="filter-btn" data-filter="mobile">
                Mobile
              </button>
            </div>
          )
        }

        <div class="gallery-groups">
          {
            desktopImages.length > 0 && (
              <div class="gallery-group" data-device="desktop">
                {hasMultipleDevices && <p class="device-label">Desktop</p>}
                <div class="desktop-grid">
                  {desktopImages.map((img, index) => (
                    <a
                      href={img.src.src}
                      data-fancybox="gallery"
                      data-caption={img.alt}
                      class="gallery-link desktop-item"
                      aria-label={`View ${img.alt} fullscreen`}
                    >
                      <Image
                        src={img.src}
                        alt={img.alt}
                        loading={index < 2 ? "eager" : "lazy"}
                        fetchpriority={index === 0 ? "high" : "auto"}
                      />
                    </a>
                  ))}
                </div>
              </div>
            )
          }

          {
            mobileImages.length > 0 && (
              <div class="gallery-group" data-device="mobile">
                {hasMultipleDevices && <p class="device-label">Mobile</p>}
                <div class="mobile-grid">
                  {mobileImages.map((img, index) => (
                    <a
                      href={img.src.src}
                      data-fancybox="gallery"
                      data-caption={img.alt}
                      class="gallery-link mobile-item"
                      aria-label={`View ${img.alt} fullscreen`}
                    >
                      <Image
                        src={img.src}
                        alt={img.alt}
                        loading={desktopImages.length > 0 ? "lazy" : (index < 3 ? "eager" : "lazy")}
                        fetchpriority={desktopImages.length === 0 && index === 0 ? "high" : "auto"}
                      />
                    </a>
                  ))}
                </div>
              </div>
            )
          }
        </div>
      </section>
    </div>
  </article>
</Layout>

<style>
  .project-detail {
    padding-top: var(--spacing-section);
    padding-bottom: var(--spacing-section);
  }

  /* Header */
  .project-header {
    max-width: 720px;
    margin-bottom: 4rem;

    h1 {
      margin-top: 1rem;
      margin-bottom: 1rem;
    }
  }

  .back-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-primary);
    opacity: 0.8;
    transition: opacity 0.2s ease;

    &:hover {
      opacity: 1;
    }
  }
  .tags {
    flex-wrap: wrap;
  }

  .description {
    font-size: var(--text-normal);
    opacity: 0.85;
    max-width: 65ch;
    margin-bottom: 2rem;
  }

  .actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Gallery Layout */
  .gallery {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .gallery-group {
    display: flex;
    flex-direction: column;
    padding-bottom: 2.5rem;
    gap: 1rem;
    transition: opacity 0.2s ease;

    &.hidden {
      display: none;
    }
  }

  .device-label {
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary-light);
    opacity: 0.7;
    margin: 0;
  }

  .desktop-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;

    @media (min-width: 36rem) {
      grid-template-columns: repeat(2, 1fr);
    }

    @media (min-width: 62rem) {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .mobile-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  /* Base Image Link Styles */
  .gallery-link {
    display: block;
    position: relative;
    cursor: hand;
    border-radius: var(--rounding);
    overflow: hidden;
    box-shadow: var(--shadow);
    background: rgba(255, 255, 255, 0.03);

    &::after {
      content: "";
      position: absolute;
      inset: 0;
      background: transparent;
      transition: background 0.2s ease;
    }

    &:hover::after {
      background: rgba(255, 221, 51, 0.08);
    }

    img {
      display: block;
      width: 100%;
      height: auto;
      object-fit: cover;
    }
  }

  /* Desktop Modifiers */
  .desktop-item {
    border: 1px solid rgba(255, 255, 255, 0.12);

    img {
      aspect-ratio: 16 / 9;
    }
  }

  /* Mobile Modifiers */
  .mobile-item {
    width: 235px;
    flex-shrink: 0;
    border: 1px solid rgba(255, 255, 255, 0.15);

    img {
      aspect-ratio: 9 / 19.5;
    }
  }

  /* Filter Bar */
  .filter-bar {
    display: flex;
    gap: 0.5rem;
  }

  .filter-btn {
    all: unset;
    cursor: pointer;
    font-family: var(--font-text);
    font-size: var(--text-xs);
    font-weight: 500;
    padding: 0.35rem 0.875rem;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: var(--color-text);
    opacity: 0.6;
    transition: all 0.2s ease;

    &:hover {
      opacity: 1;
      border-color: rgba(255, 255, 255, 0.3);
    }

    &.active {
      background: var(--color-primary-bg);
      border-color: var(--color-primary);
      color: var(--color-primary-light);
      opacity: 1;
    }

    &:focus-visible {
      outline: 2px solid var(--color-primary);
      outline-offset: 2px;
    }
  }
</style>

<script>
  import { Fancybox } from "@fancyapps/ui/dist/fancybox/";

  // ── Fancybox options ─────────────────────────────────────────────────────────
  const fancyboxOpts = {
    mainStyle: {
      "--f-button-width": "44px",
      "--f-button-height": "44px",
      "--f-button-border-radius": "50%",
      "--f-toolbar-padding": "16px",
    },
    Carousel: {
      Arrows: false,
      Toolbar: {
        display: {
          left: [],
          middle: [],
          right: ["close"],
        },
      },
      transition: "slide",
    },
  };

  // ── Gallery click handlers ───────────────────────────────────────────────────
  const allLinks = Array.from(
    document.querySelectorAll<HTMLAnchorElement>(".gallery-link"),
  );

  allLinks.forEach((link) => {
    link.addEventListener("click", (e) => {
      e.preventDefault();

      const visibleLinks = allLinks.filter(
        (l) =>
          !l
            .closest<HTMLElement>(".gallery-group")
            ?.classList.contains("hidden"),
      );

      const startIndex = visibleLinks.indexOf(link);

      Fancybox.show(
        visibleLinks.map((l) => ({
          src: l.href,
          caption: l.dataset.caption ?? "",
        })),
        {
          ...fancyboxOpts,
          startIndex: startIndex === -1 ? 0 : startIndex,
        },
      );
    });
  });

  // ── Filter ──────────────────────────────────────────────────────────────────
  const filterBtns =
    document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const groups = document.querySelectorAll<HTMLElement>(
    ".gallery-group[data-device]",
  );

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter!;
      filterBtns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      groups.forEach((group) => {
        group.classList.toggle(
          "hidden",
          filter !== "all" && filter !== group.dataset.device,
        );
      });
    });
  });
</script>
