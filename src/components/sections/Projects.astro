---
import ProjectCard from "@components/ProjectCard.astro";

const projects = [
  {
    title: "SVC Commerce",
    description:
      "A comprehensive Laravel 12 back-office platform managing catalog, inventory workflows, sales, deliveries, and PayMongo payment integration.",
    tags: ["Laravel", "Filament", "Livewire", "TailwindCSS", "PostgreSQL"],
    githubUrl: "https://github.com/KaiyouS/svc-commerce",
    imageUrl: "/images/svc-commerce.jpg",
  },
  {
    title: "GradPass",
    description:
      "A multi-platform clearance tracker resolving university administrative bottlenecks. Features role-based workflows for students, staff, and admins.",
    tags: ["Flutter", "Supabase", "Edge Functions", "Dart"],
    githubUrl: "https://github.com/KaiyouS/student_clearance_tracker",
    imageUrl: "/images/gradpass.jpg",
  },
  {
    title: "CSSEC Web Portal",
    description:
      "Architected a headless WordPress CMS to serve dynamic content via REST API. Configured content models and endpoints to seamlessly supply data to a decoupled React/Vite frontend built by collaborative team members.",
    tags: ["WordPress", "Headless CMS", "REST API", "Backend Architecture"],
    liveUrl: "https://addu-cssec-website.netlify.app/",
    imageUrl: "/images/cssec.jpg",
  },
  {
    title: "AdDU Rebrand",
    description:
      "A modern, event-driven website redesign featuring dynamic content rendering from JSON, custom search overlays, and responsive mobile architecture.",
    tags: ["Vanilla JS", "HTML5", "CSS3", "DOM Manipulation"],
    githubUrl: "https://github.com/KaiyouS/addu-website-rebranding",
    liveUrl: "https://kaiyous.github.io/addu-website-rebranding/",
    imageUrl: "/images/addu-rebrand.jpg",
  },
  {
    title: "IMS Desktop",
    description:
      "A robust Java Swing desktop application for managing inventory, suppliers, and purchase orders, backed by a relational database.",
    tags: ["Java", "Swing", "MySQL", "OOP"],
    githubUrl: "https://github.com/KaiyouS/ims-db-exercises",
    imageUrl: "/images/ims.jpg",
  },
];
---

<section id="projects" class="section projects-section">
  <div class="container">
    <div class="section-header">
      <h2>Selected Works</h2>
      <p>
        A collection of applications I've built focusing on complex workflows,
        responsive design, and scalable architecture.
      </p>
    </div>

    <div class="projects-grid">
      {
        projects.map((project) => (
          <ProjectCard
            title={project.title}
            description={project.description}
            tags={project.tags}
            githubUrl={project.githubUrl}
            liveUrl={project.liveUrl}
            imageUrl={project.imageUrl}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .section {
    padding-top: var(--spacing-section);
    padding-bottom: var(--spacing-section);
  }

  .section-header {
    margin-bottom: 4rem;
    max-width: 600px;
  }

  .section-header p {
    font-size: 1.1rem;
    opacity: 0.8;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 48rem) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
