---
import { Image } from "astro:assets";

interface Props {
  slug: string;
  title: string;
  description: string;
  tags: string[];
  githubUrl?: string;
  liveUrl?: string;
  image: {
    src: ImageMetadata;
    alt: string;
    device: "desktop" | "mobile";
  };
  eagerLoad?: boolean; 
}

const { 
  slug, 
  title, 
  description, 
  tags, 
  githubUrl, 
  liveUrl, 
  image,
  eagerLoad = false 
} = Astro.props;
---

<article class="project-card">
  <a
    href={`/projects/${slug}`}
    class="card-image"
    aria-label={`View ${title} details`}
  >
    <Image 
      src={image.src} 
      alt={image.alt} 
      loading={eagerLoad ? "eager" : "lazy"}
    />
    <span class="card-overlay">View Project</span>
  </a>

  <div class="card-content">
    <h3>
      <a href={`/projects/${slug}`}>{title}</a>
    </h3>
    <p>{description}</p>

    <div class="tags">
      {tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>

    <div class="card-actions">
      {
        githubUrl && (
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="link-raw"
          >
            GitHub &rarr;
          </a>
        )
      }
      {
        liveUrl && (
          <a
            href={liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="link-raw"
          >
            Live Demo &rarr;
          </a>
        )
      }
    </div>
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--rounding);
    overflow: hidden;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease;
    box-shadow: var(--shadow);

    &:hover {
      transform: translateY(-5px);
      border-color: rgba(255, 255, 255, 0.2);
    }
  }

  .card-image {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    display: block;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--color-bg), transparent 30%);
    color: var(--color-primary);
    font-weight: 700;
    font-size: var(--text-sm);
    letter-spacing: 0.1rem;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .project-card:hover .card-image img {
    transform: scale(1.05);
  }

  .project-card:hover .card-overlay {
    opacity: 1;
  }

  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  h3 {
    margin-top: 0;
    margin-bottom: 0.5rem;
    font-size: var(--text-md);

    a {
      color: inherit;
      text-decoration: none;
      transition: color 0.2s ease;

      &:hover {
        color: var(--color-primary);
      }
    }
  }

  p {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: 0.95rem;
    opacity: 0.8;
    margin-bottom: 1.5rem;
  }

  .card-actions {
    display: flex;
    gap: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 1rem;
  }

  .link-raw {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
    transition: color 0.2s ease;

    &:hover {
      color: var(--color-primary);
    }
  }
</style>