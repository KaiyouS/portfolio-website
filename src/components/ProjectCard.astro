---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description: string;
  tags: string[];
  githubUrl?: string;
  liveUrl?: string;
  image: {
    src: ImageMetadata;
    alt: string;
    device: "desktop" | "mobile";
  };
}

const { title, description, tags, githubUrl, liveUrl, image } = Astro.props;
---

<article class="project-card">
  <div class="card-image">
    <Image src={image.src} alt={image.alt} />
  </div>

  <div class="card-content">
    <h3>{title}</h3>
    <p>{description}</p>

    <div class="tags">
      {tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>

    <div class="card-actions">
      {
        githubUrl && (
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="link-raw"
          >
            GitHub &rarr;
          </a>
        )
      }
      {
        liveUrl && (
          <a
            href={liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="link-raw"
          >
            Live Demo &rarr;
          </a>
        )
      }
    </div>
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    background: rgba(
      255,
      255,
      255,
      0.03
    ); /* Extremely subtle card background */
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1rem;
    overflow: hidden;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease;

    box-shadow: var(--shadow);

    &:hover {
      transform: translateY(-5px);
    }
  }

  .card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .project-card:hover .card-image img {
    transform: scale(1.05);
  }

  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  h3 {
    margin-top: 0;
    margin-bottom: 0.5rem;
    font-size: var(--text-lg);
  }

  p {
    font-size: 0.95rem;
    opacity: 0.8;
    margin-bottom: 1.5rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    margin-top: auto;
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    background: var(--color-primary-bg);
    color: var(--color-primary-light);
    border-radius: 100px;
  }

  .card-actions {
    display: flex;
    gap: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 1rem;
  }

  .link-raw {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
    transition: color 0.2s ease;
  }

  .link-raw:hover {
    color: var(--color-primary);
  }
</style>
